name: Publish to PyPI

on:
  release:
    types: [published]
  pull_request:
    branches:
      - main
    paths:
      - "docs/**"
      - "README.md"
      - "CONTRIBUTING.md"
      - ".github/workflows/cd.yml"
  workflow_dispatch:

permissions:
  contents: read
  pages: write
  id-token: write

jobs:
  pypi-publish:
    name: upload release to PyPI
    runs-on: ubuntu-latest
    if: github.event_name == 'release'
    permissions:
      id-token: write
      contents: read
    steps:
      - uses: actions/checkout@v6
      - uses: astral-sh/setup-uv@v8.2.0
      - run: uv build
      - run: uv publish

      - name: Refresh demo repository
        if: github.event_name == 'release'
        env:
          DEMO_REPO_TOKEN: {% raw %}${{ secrets.DEMO_REPO_TOKEN }}{% endraw %}
        run: |
          git clone "https://x-access-token:${DEMO_REPO_TOKEN}@github.com/mgaitan/yet-another-demo.git" /tmp/yet-another-demo
          uvx --with copier-template-extensions --with . copier update --trust --defaults /tmp/yet-another-demo
          cd /tmp/yet-another-demo
          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
          if git diff --quiet; then
            echo "Demo repository already up to date"
            exit 0
          fi
          git add .
          git commit -m "chore: update project template to {% raw %}${{ github.event.release.tag_name }}{% endraw %}"
          git push origin HEAD:main

  docs-publish:
    name: Publish documentation to GitHub Pages
    runs-on: ubuntu-latest
    if: github.event_name != 'pull_request' || github.event.pull_request.head.repo.full_name == github.repository
    environment:
      name: {% raw %}${{ github.event_name == 'pull_request' && 'github-pages-preview' || 'github-pages' }}{% endraw %}
      url: {% raw %}${{ steps.preview_url.outputs.url }}{% endraw %}
    steps:
      - uses: actions/checkout@v6
        with:
          fetch-depth: 0
      - name: Detect documentation preview target
        id: preview
        run: |
          if [ "{% raw %}${{ github.event_name }}{% endraw %}" = "pull_request" ]; then
            branch="{% raw %}${GITHUB_HEAD_REF:-${GITHUB_REF_NAME}}{% endraw %}"
            slug="$(printf '%s' "$branch" | tr '[:upper:]' '[:lower:]' | tr '/' '-' | tr -cs 'a-z0-9._-' '-' | sed 's/^-//;s/-$//')"
            echo "docs_subdir=_preview/${slug}" >> "$GITHUB_OUTPUT"
          fi
      - uses: actions/configure-pages@v5
      - uses: astral-sh/setup-uv@v8.2.0
      - name: Build docs for current ref
        run: |
          make docs
          mv docs/_build/html docs/_build/html-current

      - name: Build stable docs from latest release
        if: {% raw %}${{ github.event_name == 'pull_request' }}{% endraw %}
        run: |
          stable_ref="$(git tag --sort=-version:refname | head -n1 || true)"
          if [ -z "$stable_ref" ]; then
            stable_ref="$(git tag --sort=-creatordate | head -n1 || true)"
          fi
          if [ -z "$stable_ref" ]; then
            echo "No release tag found; using main as stable docs fallback" >&2
            stable_ref="origin/main"
          fi
          git worktree add ../project-stable "$stable_ref"
          cd ../project-stable
          make docs

      - name: Stage documentation artifact
        run: |
          out_dir="site"
          subdir="{% raw %}${{ steps.preview.outputs.docs_subdir }}{% endraw %}"
          rm -rf "$out_dir"
          if [ -n "$subdir" ]; then
            mkdir -p "$out_dir/$subdir"
            cp -a ../project-stable/docs/_build/html/. "$out_dir/"
            cp -a docs/_build/html-current/. "$out_dir/$subdir/"
          else
            mkdir -p "$out_dir"
            cp -a docs/_build/html-current/. "$out_dir/"
          fi
      - uses: actions/upload-pages-artifact@v4
        with:
          path: site
      - id: deployment
        uses: actions/deploy-pages@v4
      - name: Compute documentation URL
        id: preview_url
        run: |
          url="{% raw %}${{ steps.deployment.outputs.page_url }}{% endraw %}"
          subdir="{% raw %}${{ steps.preview.outputs.docs_subdir }}{% endraw %}"
          if [ -n "$subdir" ]; then
            url="${url%/}/${subdir}"
          fi
          echo "url=${url}" >> "$GITHUB_OUTPUT"
      - name: Summarize documentation URL
        run: |
          echo "Documentation published at: {% raw %}${{ steps.preview_url.outputs.url }}{% endraw %}" >> "$GITHUB_STEP_SUMMARY"

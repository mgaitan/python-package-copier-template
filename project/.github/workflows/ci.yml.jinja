name: CI
on:
  pull_request:
    branches:
      - main
  push:
    branches:
      - main

jobs:
  changes:
    runs-on: ubuntu-latest
    outputs:
      python: {% raw %}${{ steps.filter.outputs.python }}{% endraw %}
      workflows: {% raw %}${{ steps.filter.outputs.workflows }}{% endraw %}
    steps:
      - uses: actions/checkout@v6
      - uses: dorny/paths-filter@v3
        id: filter
        with:
          filters: |
            python:
              - 'pyproject.toml'
              - 'uv.lock'
              - 'src/**'
              - 'tests/**'
              - 'Makefile'
            workflows:
              - '.github/workflows/**'

  workflows-lint:
    needs: changes
    if: {% raw %}${{ needs.changes.outputs.workflows == 'true' }}{% endraw %}
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6
      - name: Lint GitHub workflows
        uses: rhysd/actionlint@v1.7.12

  qa:
    needs: changes
    if: {% raw %}${{ needs.changes.outputs.python == 'true' }}{% endraw %}
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6
      - uses: astral-sh/setup-uv@v8.2.0

      - name: Ruff check
        run: uv run --only-group lint ruff check --output-format=github

      - name: Ruff format
        run: uv run --only-group lint ruff format --check

      - name: Ty check
        run: uv run --group qa ty check --output-format=github


  test:
    needs: [changes, qa]
    if: {% raw %}${{ needs.changes.outputs.python == 'true' }}{% endraw %}
    runs-on: ubuntu-latest
    strategy:
      matrix:
        python-version: ["3.12", "3.13", "3.14"]

    steps:
      - uses: actions/checkout@v6
      - uses: astral-sh/setup-uv@v8.2.0
      - name: Run tests with coverage
        run: uv run --group test -p {% raw %}${{ matrix.python-version }}{% endraw %} pytest
